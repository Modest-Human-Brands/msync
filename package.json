{
  "name": "red-cat-pictures-tools",
  "version": "0.0.0",
  "description": "Bulk Watermark adding & file reorganizing tool",
  "author": "Shirsendu Bairagi <shirsendu2001@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Algostract/red-cat-pictures-tools.git"
  },
  "keywords": [],
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.mjs",
      "require": "./dist/cli.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": "./bin/rcp-tools.mjs",
  "pkg": {
    "assets": [
      "node_modules/sharp/**/*"
    ],
    "scripts": [
      ",/bin/rcp-tools.mjs"
    ]
  },
  "files": [
    "dist",
    "bin"
  ],
  "engines": {
    "node": "^20.15.0 || ^22.11.0",
    "pnpm": "^9.15.0 || ^10.2.0",
    "bun": "^1.2.9"
  },
  "packageManager": "bun@1.2.22",
  "scripts": {
    "prepare": "husky || true",
    "dev": "dotenvx run -- vitest dev",
    "detect": "gitleaks git --verbose",
    "lint": "eslint . --fix",
    "format": "prettier . --write",
    "test:types": "tsc --noEmit --skipLibCheck",
    "test": "bun lint && bun test:types && dotenvx run -- vitest run --coverage",
    "play": "dotenvx run -- jiti examples",
    "build": "unbuild",
    "bun:build": "bun run build && bun build bin/rcp-tools.mjs --compile --production --outfile=dist/bin/rcp-tools.exe",
    "prepack": "bun run build",
    "clean": "rm -rf coverage dist",
    "rcp-tools": "./dist/bin/rcp-tools.exe"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@inquirer/prompts": "^7.8.6",
    "@napi-rs/canvas": "^0.1.80",
    "@types/cli-progress": "^3.11.6",
    "chalk": "^5.6.2",
    "citty": "^0.1.6",
    "cli-progress": "^3.12.0",
    "consola": "^3.4.2",
    "execa": "^9.6.0",
    "ofetch": "^1.4.1",
    "ora": "^9.0.0",
    "std-env": "^3.9.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@dotenvx/dotenvx": "^1.50.1",
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.36.0",
    "eslint-config-unjs": "^0.5.0",
    "husky": "^9.1.7",
    "jiti": "^2.5.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "unbuild": "3.5.0",
    "vitest": "^3.2.4"
  }
}